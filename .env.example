# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=grafana

# Password for the Grafana Alloy monitoring user (db-o11y)
DB_O11Y_PASSWORD=changeme

# Password for the PostgreSQL streaming replication user
REPLICATOR_PASSWORD=changeme_repl

# ── Grafana Enterprise ───────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme
# Paste your Enterprise license key here (leave blank for 30-day trial mode)
GF_ENTERPRISE_LICENSE_TEXT=

# ── Grafana PDC Agent ─────────────────────────────────────────
# From Grafana Cloud UI → Configuration Details
GCLOUD_PDC_SIGNING_TOKEN=
GCLOUD_HOSTED_GRAFANA_ID=
GCLOUD_PDC_CLUSTER=

# ── Grafana Alloy → Grafana Cloud ─────────────────────────────
# From Grafana Cloud UI → Stack → Details
GCLOUD_HOSTED_METRICS_URL=https://prometheus-prod-XX-prod-XX.grafana.net/api/prom/push
GCLOUD_HOSTED_METRICS_ID=
GCLOUD_HOSTED_LOGS_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GCLOUD_HOSTED_LOGS_ID=
# API token with MetricsPublisher + LogsPublisher scopes
GCLOUD_RW_API_KEY=
